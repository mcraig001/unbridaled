# UNBRIDALED — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe (TEST mode during build — do NOT activate live keys until operator approval)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Plaid (SANDBOX during build — Production requires operator approval)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_ENV=sandbox

# HUD API (for Fair Market Rents)
# Sign up at: https://www.huduser.gov/hudapi/public/register/form
HUD_API_TOKEN=your_hud_api_token

# Resend (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@[DOMAIN_TBD]

# Legal gate (S6/G7) — set to "true" only after attorney review, ICP testing, Plaid production approval
LEGAL_REVIEW_COMPLETE=false

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Internal
INTERNAL_API_SECRET=generate_a_random_secret_here
